f_TIME_getTradingDayIndex() =>
    0

// Purpose: Return the current week number.
// Inputs: None.
// Outputs: The current week number.
f_TIME_getWeekNumber() =>
    weekofyear(time)

// Purpose: Return the placeholder month number.
// Inputs: None.
