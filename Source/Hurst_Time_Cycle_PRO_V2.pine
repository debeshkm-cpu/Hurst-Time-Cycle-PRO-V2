// ============================================================================
// SECTION 04
// Utility Library
// ============================================================================
// Purpose: Clamp a numeric value within a defined range.
// Inputs: value, minValue, maxValue.
// Returns: A clamped numeric value.
f_clamp(float value, float minValue, float maxValue) =>
    math.max(minValue, math.min(value, maxValue))

// Purpose: Normalize a value into a range between 0 and 1.
// Inputs: value, minValue, maxValue.
// Returns: A normalized float value.
f_normalize(float value, float minValue, float maxValue) =>
    if maxValue <= minValue
        0.0
    else
        (value - minValue) / (maxValue - minValue)

// Purpose: Safely divide two numeric values.
// Inputs: numerator, denominator.
// Returns: Zero when the denominator is zero, otherwise the division result.
f_safeDivide(float numerator, float denominator) =>
    if denominator == 0.0
        0.0
    else
        numerator / denominator

// Purpose: Return the absolute distance between two numeric values.
// Inputs: valueA, valueB.
// Returns: The absolute difference between the two values.
f_distance(float valueA, float valueB) =>
    math.abs(valueA - valueB)

// Purpose: Return a boolean value as-is.
// Inputs: value.
// Returns: The boolean input value.
f_isTrue(bool value) =>
    value

// Purpose: Return the negation of a boolean value.
// Inputs: value.
// Returns: The inverted boolean value.
f_isFalse(bool value) =>
    not value

// Purpose: Return the current chart type.
// Inputs: None.
// Returns: The chart type as a string.
f_getChartType() =>
    syminfo.type

// Purpose: Check whether the current timeframe is intraday.
// Inputs: None.
// Returns: True when the current timeframe is intraday.
f_isIntradayTimeframe() =>
    timeframe.isintraday

// ============================================================================
// SECTION 05
// Validation Library
// ============================================================================
// Purpose: Validate a cycle length value.
// Inputs: cycleLength.
// Returns: True when the value is within the supported range.
f_isValidCycleLength(int cycleLength) =>
    cycleLength >= MIN_CYCLE_LENGTH and cycleLength <= MAX_CYCLE_LENGTH

// Purpose: Validate a projection depth value.
// Inputs: projectionDepth.
// Returns: True when the value is within the supported range.
f_isValidProjectionDepth(int projectionDepth) =>
    projectionDepth >= MIN_PROJECTION_DEPTH and projectionDepth <= MAX_PROJECTION_DEPTH

// Purpose: Validate an anchor timestamp.
// Inputs: anchorTimestamp.
// Returns: True when the timestamp is present and valid.
f_isValidAnchorTimestamp(int anchorTimestamp) =>
    not na(anchorTimestamp) and anchorTimestamp > 0

// Purpose: Validate a window size value.
// Inputs: windowSize.
// Returns: True when the window size is within the supported range.
f_isValidWindowSize(int windowSize) =>
    windowSize >= MIN_WINDOW_SIZE and windowSize <= MAX_WINDOW_SIZE

// Purpose: Validate a general input value.
// Inputs: inputValue.
// Returns: True when the input value is not na.
f_isValidGeneralInput(float inputValue) =>
    not na(inputValue)

