// Purpose: Trim leading and trailing whitespace from a string.
// Inputs: sourceText - the original string to clean.
// Outputs: A trimmed string without surrounding whitespace.
// Future responsibilities: Support broader string sanitization when needed.
f_UTIL_trimString(sourceText) =>
    string trimmedText = sourceText
    int startIndex = 0
    int endIndex = str.length(trimmedText)

    while startIndex < endIndex and (str.substring(trimmedText, startIndex, startIndex + 1) == " " or str.substring(trimmedText, startIndex, startIndex + 1) == "\t" or str.substring(trimmedText, startIndex, startIndex + 1) == "\n" or str.substring(trimmedText, startIndex, startIndex + 1) == "\r")
        startIndex := startIndex + 1

    while endIndex > startIndex and (str.substring(trimmedText, endIndex - 1, endIndex) == " " or str.substring(trimmedText, endIndex - 1, endIndex) == "\t" or str.substring(trimmedText, endIndex - 1, endIndex) == "\n" or str.substring(trimmedText, endIndex - 1, endIndex) == "\r")
        endIndex := endIndex - 1

    str.substring(trimmedText, startIndex, endIndex)

// Purpose: Preserve the original cycle string input as a configuration value.
// Inputs: cycleInput - the raw cycle string supplied by the user.
// Outputs: The trimmed string value without any conversion attempt.
// Future responsibilities: Replace with a robust cycle-string parser when supported.
f_CFG_validateCycleString(cycleInput) =>
    f_UTIL_trimString(cycleInput)

// Purpose: Preserve the raw intraday cycle configuration.
// Inputs: None.
// Outputs: A safe placeholder configuration string.
